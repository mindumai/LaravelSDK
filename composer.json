{
    "name": "mindum/laravel",
    "description": "The agent layer for Laravel — auto-generated MCP tools from your codebase.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "mcp",
        "model-context-protocol",
        "ai",
        "agent",
        "anthropic",
        "claude",
        "copilot",
        "chatbot"
    ],
    "homepage": "https://mindum.online",
    "support": {
        "issues": "https://github.com/mindumai/LaravelSDK/issues",
        "source": "https://github.com/mindumai/LaravelSDK"
    },
    "authors": [
        {
            "name": "Azhar",
            "email": "277364814+mindumai@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "laravel/mcp": "^0.5.3|^0.7",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Mindum\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mindum\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mindum\\Laravel\\MindumServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
